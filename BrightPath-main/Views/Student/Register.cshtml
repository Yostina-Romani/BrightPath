@model BrightPath.ViewModels.RegisterViewModel

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma;
        background: #0b1220;
        color: #e2e8f0;
    }

    .container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 20px;
    }

    /* CARD */
    .card {
        width: 450px;
        padding: 30px;
        border-radius: 22px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(56,189,248,0.15);
        backdrop-filter: blur(12px);
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        position: relative;
        overflow: hidden;
    }

        .card::before {
            content: "";
            position: absolute;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(249,168,212,0.25), transparent);
            top: -60px;
            right: -60px;
        }

    h3 {
        text-align: center;
        font-size: 26px;
        font-weight: 900;
        background: linear-gradient(135deg, #38bdf8, #f9a8d4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 6px;
    }

    p {
        text-align: center;
        color: #94a3b8;
        margin-bottom: 25px;
    }

    /* INPUTS */
    .form-label {
        font-size: 13px;
        color: #cbd5e1;
        margin-bottom: 6px;
        display: block;
    }

    .form-control {
        width: 100%;
        padding: 12px 14px;
        border-radius: 12px;
        border: 1px solid rgba(56,189,248,0.2);
        background: rgba(255,255,255,0.03);
        color: #e2e8f0;
        outline: none;
        transition: .3s;
    }

        .form-control:focus {
            border-color: #38bdf8;
            box-shadow: 0 0 0 3px rgba(56,189,248,0.15);
        }

    /* INPUT GROUP */
    .input-group {
        display: flex;
        gap: 6px;
    }

        .input-group button {
            border: none;
            border-radius: 12px;
            padding: 0 12px;
            background: rgba(56,189,248,0.15);
            color: #38bdf8;
            cursor: pointer;
        }

    /* SELECT */
    select.form-control {
        cursor: pointer;
    }

    /* BUTTON */
    .btn {
        width: 100%;
        padding: 12px;
        border-radius: 14px;
        border: none;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        background: linear-gradient(135deg, #38bdf8, #f9a8d4);
        color: white;
        margin-top: 10px;
        transition: .3s;
    }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(56,189,248,0.2);
        }

    /* LINK */
    a {
        color: #7dd3fc;
        text-decoration: none;
    }

        a:hover {
            color: #f9a8d4;
        }

    .text-center {
        text-align: center;
    }

    hr {
        border: none;
        height: 1px;
        background: rgba(56,189,248,0.15);
        margin: 20px 0;
    }

</style>

<div class="container">

    <div class="card">

        <h3>Create Account 🚀</h3>
        <p>Join BrightPath and start learning</p>
        <div asp-validation-summary="All" class="text-danger"></div>
        <form method="post"asp-action="Register" asp-controller="Student" >

            <label class="form-label">Name</label>
            <input asp-for="name" class="form-control" />
            <span asp-validation-for="name" class="text-danger small"></span>

            <br />

            <label class="form-label">Email</label>
            <input asp-for="email" class="form-control" />
            <span asp-validation-for="email" class="text-danger small"></span>

            <br />

            <label class="form-label">Password</label>
            <div class="input-group">
                <input asp-for="password" type="password" id="passInput" class="form-control" />
                <button type="button" onclick="togglePass('passInput')">👁</button>
            </div>

            <span asp-validation-for="password" class="text-danger small"></span>

            <br />

            <label class="form-label">Confirm Password</label>
            <div class="input-group">
                <input asp-for="confirmpass" type="password" id="confirmPassInput" class="form-control" />
                <button type="button" onclick="togglePass('confirmPassInput')">👁</button>
            </div>

            <span asp-validation-for="confirmpass" class="text-danger small"></span>

            <br />

            <label class="form-label">Age</label>
            <input asp-for="age" class="form-control" />

            <br />

            <label class="form-label">Grade</label>
            <select asp-for="gradeid" asp-items="ViewBag.grades" class="form-control">
                <option value="">-- select your grade --</option>
            </select>

            <button type="submit" class="btn">
                Create Account
            </button>

        </form>

        <hr />

        <div class="text-center">
            <small>Already have an account?</small><br />
            <a asp-action="Login" asp-controller="Student">Login</a>
        </div>

    </div>
</div>

<script>
    function togglePass(id) {
        var input = document.getElementById(id);
        input.type = input.type === "password" ? "text" : "password";
    }
</script>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}