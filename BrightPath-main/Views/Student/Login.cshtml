@model BrightPath.ViewModels.LoginViewModels

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma;
        background: #0b1220;
        color: #e2e8f0;
    }

    .container-box {
        min-height: 85vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }


    /* شكل رسالة الخطأ */
    .field-validation-error {
        color: #f87171;
        font-size: 13px;
        margin-top: 5px;
        display: block;
    }

    /* input عادي (بدون error) */
    input {
        border: 1px solid rgba(56,189,248,0.3);
    }

        /* input وقت الخطأ فقط */
        input.input-validation-error {
            border: 1px solid #f87171 !important;
            box-shadow: 0 0 8px rgba(248,113,113,0.3) !important;
        }

    .validation-summary-valid {
        display: none;
    }

    .validation-summary-errors {
        background: rgba(239,68,68,0.15);
        color: #f87171;
        padding: 10px;
        border-radius: 10px;
        text-align: center;
        margin-bottom: 15px;
        border: 1px solid rgba(239,68,68,0.3);
    }
    /* CARD */
    .card {
        width: 420px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(56,189,248,0.2);
        backdrop-filter: blur(10px);
        border-radius: 22px;
        padding: 30px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        transition: .3s;
    }

        .card:hover {
            transform: translateY(-6px);
        }

    h3 {
        text-align: center;
        font-weight: 900;
        background: linear-gradient(135deg, #38bdf8, #f9a8d4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 5px;
    }

    p {
        text-align: center;
        color: #94a3b8;
        margin-bottom: 25px;
    }

    label {
        font-size: 13px;
        color: #cbd5e1;
        margin-bottom: 6px;
        display: block;
    }

    input {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid rgba(56,189,248,0.3);
        background: rgba(255,255,255,0.05);
        color: white;
        outline: none;
        transition: .3s;
    }

        input:focus {
            border-color: #38bdf8;
            box-shadow: 0 0 10px rgba(56,189,248,0.3);
        }

    .input-group {
        display: flex;
        gap: 10px;
    }

    .btn-toggle {
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        border: none;
        border-radius: 10px;
        padding: 10px 12px;
        cursor: pointer;
        color: white;
        font-size: 14px;
    }

    .btn-login {
        width: 100%;
        margin-top: 15px;
        padding: 12px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        color: white;
        font-weight: 700;
        cursor: pointer;
        transition: .3s;
    }

        .btn-login:hover {
            transform: scale(1.03);
        }

    .link {
        text-align: center;
        margin-top: 15px;
    }

        .link a {
            color: #38bdf8;
            text-decoration: none;
            font-weight: 600;
        }

    .error {
        background: rgba(239,68,68,0.15);
        color: #f87171;
        padding: 10px;
        border-radius: 10px;
        text-align: center;
        margin-bottom: 15px;
        border: 1px solid rgba(239,68,68,0.3);
    }

</style>

<div class="container-box">

    <div class="card">

        <h3>Welcome Back 👋</h3>
        <p>Login to continue learning</p>

        <div asp-validation-summary="All"></div>
        <form method="post">

            <div style="margin-bottom:15px;">
                <label>Email</label>
                <input asp-for="email" placeholder="Enter your email" />
                <span asp-validation-for="email" class="text-danger"></span>
            </div>

            <div style="margin-bottom:15px;">
                <label>Password</label>

                <div class="input-group">
                    <input asp-for="password"
                           type="password"
                           id="passwordInput"
                           placeholder="Enter password" />

                    <button type="button" class="btn-toggle"
                            onclick="togglePassword()">
                        👁
                    </button>
                </div>

                <span asp-validation-for="password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-login">
                Login
            </button>

        </form>

        <div class="link">
            <small>Don't have an account?</small><br />
            <a asp-action="Register" asp-controller="Student">Create Account</a>
        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword() {
            var p = document.getElementById("passwordInput");
            p.type = (p.type === "password") ? "text" : "password";
        }
    </script>
}