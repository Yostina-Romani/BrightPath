<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma;
        background: #0b1220;
        color: #e2e8f0;
    }

    .dashboard {
        max-width: 1200px;
        margin: auto;
        padding: 40px 20px;
    }

    /* HEADER */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 30px;
        padding: 25px;
        border-radius: 25px;
        background: linear-gradient(135deg, rgba(56,189,248,0.08), rgba(249,168,212,0.08));
        border: 1px solid rgba(56,189,248,0.2);
        backdrop-filter: blur(12px);
    }

    .title {
        font-size: 38px;
        font-weight: 900;
        background: linear-gradient(135deg, #38bdf8, #f9a8d4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .subtitle {
        color: #cbd5e1;
        font-size: 15px;
        margin-top: 6px;
    }

    .header img {
        width: 170px;
        border-radius: 20px;
        box-shadow: 0 25px 60px rgba(56,189,248,0.15);
        transition: .4s;
    }

        .header img:hover {
            transform: scale(1.05);
        }

    /* ERROR */
    .error {
        background: rgba(249, 168, 212, 0.1);
        border: 1px solid rgba(249, 168, 212, 0.3);
        color: #fbcfe8;
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    /* STATS */
    .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(56,189,248,0.15);
        border-radius: 22px;
        padding: 25px;
        text-align: center;
        transition: .4s;
        backdrop-filter: blur(10px);
        position: relative;
        overflow: hidden;
    }

        .card::before {
            content: "";
            position: absolute;
            width: 150px;
            height: 150px;
            background: radial-gradient(circle, rgba(249,168,212,0.25), transparent);
            top: -40px;
            right: -40px;
        }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 50px rgba(56,189,248,0.15);
        }

        .card img {
            width: 60px;
            margin-bottom: 10px;
        }

        .card h3 {
            color: #94a3b8;
            font-size: 14px;
        }

    .number {
        font-size: 38px;
        font-weight: 900;
        background: linear-gradient(135deg, #38bdf8, #f9a8d4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ACTIONS */
    .actions {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        margin-top: 10px;
    }

    .btn {
        padding: 12px 18px;
        border-radius: 14px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: .3s;
    }

        .btn:hover {
            transform: translateY(-3px);
        }

    .add {
        background: linear-gradient(135deg, #38bdf8, #22c55e);
        color: white;
        box-shadow: 0 10px 25px rgba(56,189,248,0.2);
    }

    .manage {
        background: linear-gradient(135deg, #f9a8d4, #7c3aed);
        color: white;
        box-shadow: 0 10px 25px rgba(249,168,212,0.2);
    }

    /* BACK */
    .back {
        display: block;
        text-align: center;
        margin-top: 40px;
        color: #94a3b8;
        text-decoration: none;
    }

        .back:hover {
            color: #38bdf8;
        }
</style>

<div class="dashboard">

    <!-- HEADER -->
    <div class="header">

        <div>
            <div class="title">Admin Dashboard</div>
            <div class="subtitle">Overview of your platform statistics 💜</div>
        </div>

        <!-- REALISTIC IMAGE -->
        <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=600" />
    </div>

    @if (TempData["editerror"] != null)
    {
        <div class="error">
            ⚠ @TempData["editerror"]
        </div>
    }

    <!-- STATS -->
    <div class="stats">

        <div class="card">
            <img src="https://cdn-icons-png.flaticon.com/512/3143/3143643.png" />
            <h3>Total Courses</h3>
            <div class="number">@ViewBag.course</div>
        </div>

        <div class="card">
            <img src="https://cdn-icons-png.flaticon.com/512/3163/3163508.png" />
            <h3>Total Lessons</h3>
            <div class="number">@ViewBag.lesson</div>
        </div>

    </div>

    <!-- ACTIONS -->
    <div class="actions">

        <a class="btn add"
           asp-controller="Course"
           asp-action="AddCourse">
            ➕ Add Course
        </a>

        <a class="btn manage"
           asp-controller="Admin"
           asp-action="ManageCourses">
            📚 Manage Courses
        </a>

    </div>

</div>

<a asp-action="Index" asp-controller="Home" class="back">
    ← Back to Home
</a>