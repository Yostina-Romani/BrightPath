@using System.Linq
@model List<BrightPath.Models.Course>

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma;
        background: #0b1220;
        color: #e2e8f0;
    }

    /* HERO */
    .hero {
        position: relative;
        padding: 110px 70px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 40px;
        background: radial-gradient(circle at top left, #38bdf8, transparent 40%), radial-gradient(circle at bottom right, #f9a8d4, transparent 45%), linear-gradient(135deg,#0b1220,#0f172a);
        border-radius: 0 0 60px 60px;
        overflow: hidden;
    }

    .hero-content {
        max-width: 550px;
    }

    .view-btn {
        display: inline-block;
        margin-top: 10px;
        padding: 10px 14px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
        color: white;
        background: linear-gradient(135deg, #38bdf8, #f9a8d4);
        transition: 0.3s;
        text-align: center;
    }

        .view-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(56,189,248,0.3);
        }

    .hero h1 {
        font-size: 56px;
        font-weight: 900;
        color: white;
    }

    .hero p {
        font-size: 18px;
        color: #cbd5e1;
        margin-top: 10px;
    }

    .hero-image img {
        width: 380px;
        border-radius: 20px;
        box-shadow: 0 30px 60px rgba(0,0,0,0.5);
        animation: float 4s ease-in-out infinite;
    }

    @@keyframes float {
        0% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-15px);
        }

        100% {
            transform: translateY(0);
        }
    }

    .empty {
        text-align: center;
        margin: 40px 0;
        font-size: 22px;
        color: #94a3b8;
    }
    .card {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(125,211,252,0.2);
        border-radius: 18px;
        overflow: hidden;
        transition: 0.3s;
        backdrop-filter: blur(10px);
    }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
        }

    .card-body {
        padding: 15px;
        color: #e2e8f0;
    }

        .card-body h3 {
            margin: 0;
            color: #fbcfe8;
        }

    .desc {
        font-size: 14px;
        color: #cbd5e1;
        margin: 8px 0;
    }

    .teacher {
        font-size: 13px;
        color: #94a3b8;
    }

    /* FORM */
    .enroll-form {
        margin-top: 12px;
    }

    /* BUTTON */
    .enroll-btn {
        width: 100%;
        padding: 10px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .enroll-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(56,189,248,0.3);
        }
    /* BUTTON */
    .btn {
        display: inline-block;
        margin-top: 20px;
        padding: 12px 18px;
        border-radius: 14px;
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        color: white;
        text-decoration: none;
        font-weight: 600;
        transition: .3s;
    }

        .btn:hover {
            transform: scale(1.05);
        }

    /* SECTION TITLE */
    .title {
        text-align: center;
        font-size: 34px;
        margin: 50px 0 20px;
        color: #fbcfe8;
    }

    /* WHY SECTION */
    .why {
        padding: 60px 20px;
        text-align: center;
    }

    .why-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 20px;
        margin-top: 30px;
    }

    .why-card {
        padding: 20px;
        border-radius: 18px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(249,168,212,0.25);
        transition: .3s;
    }

        .why-card:hover {
            transform: translateY(-8px);
            background: rgba(249,168,212,0.08);
        }
    /*search*/
    .search-container {
        display: flex;
        justify-content: center;
        margin: 40px auto;
    }

    .search-form {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(255,255,255,0.05);
        padding: 12px;
        border-radius: 18px;
        border: 1px solid rgba(56,189,248,0.25);
        backdrop-filter: blur(10px);
        width: min(700px, 90%);
    }

    .search-input {
        flex: 1;
        border: none;
        outline: none;
        background: transparent;
        color: white;
        font-size: 16px;
        padding: 12px;
    }

        .search-input::placeholder {
            color: #94a3b8;
        }

    .search-btn {
        border: none;
        padding: 12px 22px;
        border-radius: 14px;
        cursor: pointer;
        font-weight: 600;
        color: white;
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        transition: .3s;
    }

        .search-btn:hover {
            transform: translateY(-2px) scale(1.03);
            box-shadow: 0 10px 25px rgba(56,189,248,.3);
        }

    /* CONTACT */
    .contact {
        padding: 60px 20px;
        text-align: center;
    }

    .contact-box {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
        margin-top: 25px;
    }

    .contact-card {
        padding: 18px;
        border-radius: 15px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(56,189,248,0.3);
        width: 260px;
        transition: .3s;
    }

        .contact-card:hover {
            transform: translateY(-6px);
        }

    a {
        color: #7dd3fc;
        text-decoration: none;
    }

        a:hover {
            color: #f9a8d4;
        }

    /* COURSES */
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
        gap: 20px;
        padding: 20px;
    }

    .card {
        border-radius: 20px;
        overflow: hidden;
        background: rgba(255,255,255,0.05);
        transition: .3s;
    }

        .card:hover {
            transform: translateY(-8px);
        }

        .card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

    .card-body {
        padding: 15px;
    }
</style>

<!-- HERO -->
<div class="hero">

    <div class="hero-content">
        <h1>🎓 Learn. Grow. Succeed.</h1>
        <p>Modern learning platform with professional courses and real-world skills.</p>
        @if (!User.Identity.IsAuthenticated)
        {
            <a asp-action="Login" asp-controller="Student" class="btn">
                🚀 Start Learning
            </a>            
        }
    </div>

    <div class="hero-image">
        <img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644" />
    </div>

</div>

<!-- WHY US -->
<div class="why">
    <div class="title">✨ Why Choose Our Platform</div>

    <div class="why-grid">

        <div class="why-card">🎓 Expert Instructors</div>
        <div class="why-card">📚 Real-World Courses</div>
        <div class="why-card">💡 Easy Learning Experience</div>
        <div class="why-card">📱 Learn Anytime Anywhere</div>

    </div>
</div>
<!--search-->
<div class="search-container">

    <form asp-action="Search"
          asp-controller="Student"
          method="post"
          class="search-form">

        <input type="text"
               name="search"
               class="search-input"
               placeholder="🔍 Search for courses..." />

        <button type="submit" class="search-btn">
            Search
        </button>

    </form>

</div>
<div class="title">📚 Available Courses</div>

<!-- COURSES -->
@if (Model == null || Model.Count()==0)
{
    <div class="empty">
        No courses available.
    </div>
}
else
{

    <div class="grid">

        @foreach (var course in Model)
        {
            <div class="card">

                <img src="@course.courseImage" alt="course image" />

                <div class="card-body">
                    <h3>@course.courseName</h3>

                    <p class="desc">@course.courseDescription</p>

                    <p class="teacher">👨‍🏫 @course.teacherName</p>

                    <form method="post"
                          asp-action="Enroll"
                          asp-controller="Student"
                          class="enroll-form">

                        <input type="hidden" name="courseId" value="@course.courseId" />

                        <button type="submit" class="enroll-btn">
                            🚀 Enroll Now
                        </button>

                    </form>

                    <!-- VIEW DETAILS INSIDE CARD -->
                    <a asp-action="CourseDetails"
                       asp-controller="Course"
                       asp-route-id="@course.courseId"
                       class="view-btn">
                        📖 View Details
                    </a>

                </div>
            </div>
        }

    </div>
}

<!-- CONTACT -->
<div class="contact">

    <div class="title">📩 Contact Me</div>

    <div class="contact-box">

        <div class="contact-card">
            <h4>GitHub</h4>
            <a href="https://github.com/Yostina-Romani" target="_blank">
                github.com/Yostina-Romani
            </a>
        </div>

        <div class="contact-card">
            <h4>LinkedIn</h4>
            <a href="https://linkedin.com/in/yostina-romani-9100a737a" target="_blank">
                linkedin.com/in/yostina-romani
            </a>
        </div>

        <div class="contact-card">
            <h4>Email</h4>
            <a href="mailto:yostinaromani@gmail.com">
                yostinaromani@gmail.com
            </a>
        </div>

    </div>

</div>