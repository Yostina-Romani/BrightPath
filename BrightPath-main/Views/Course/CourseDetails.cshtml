@model Course

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma;
        background: radial-gradient(circle at top left, #38bdf8, transparent 40%), radial-gradient(circle at bottom right, #f9a8d4, transparent 45%), linear-gradient(135deg,#0b1220,#0f172a);
        color: #e2e8f0;
    }

    .container {
        max-width: 1100px;
        margin: auto;
        padding: 30px 15px;
    }

    /* ALERT */
    .alert {
        background: rgba(239,68,68,0.15);
        border: 1px solid rgba(239,68,68,0.3);
        color: #fecaca;
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    /* HERO CARD */
    .hero-card {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(125,211,252,0.2);
        backdrop-filter: blur(14px);
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 25px 70px rgba(0,0,0,0.5);
        margin-bottom: 25px;
        transition: .3s;
    }

        .hero-card:hover {
            transform: translateY(-5px);
        }

    .badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        margin-right: 6px;
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        color: white;
    }

    h2 {
        font-size: 32px;
        font-weight: 900;
        color: #fbcfe8;
        margin: 10px 0;
    }

    p {
        color: #cbd5e1;
        line-height: 1.6;
    }

    .lesson-card iframe {
        transition: 0.4s;
    }

    .lesson-card:hover iframe {
        transform: scale(1.02);
    }

    /* ENROLL BUTTON */
    .btn-primary {
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        border: none;
        padding: 12px 20px;
        border-radius: 14px;
        color: white;
        font-weight: 700;
        cursor: pointer;
        transition: .3s;
    }

        .btn-primary:hover {
            transform: scale(1.05);
            box-shadow: 0 15px 30px rgba(249,168,212,0.25);
        }

    /* SECTION TITLE */
    .section-title {
        font-size: 22px;
        font-weight: 800;
        margin: 25px 0 15px;
        color: #7dd3fc;
    }

    /* LESSON CARD */
    .lesson-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(125,211,252,0.15);
        border-radius: 18px;
        padding: 20px;
        transition: .3s;
    }

        .lesson-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

    video {
        width: 100%;
        border-radius: 14px;
    }

    .btn-small {
        padding: 8px 12px;
        border-radius: 10px;
        font-size: 12px;
        border: none;
        cursor: pointer;
    }

    .edit {
        background: #facc15;
        color: black;
    }

    .delete {
        background: #ef4444;
        color: white;
    }

    .add-btn {
        background: #22c55e;
        color: white;
        padding: 8px 14px;
        border-radius: 10px;
        text-decoration: none;
    }

    .back {
        display: inline-block;
        margin-top: 25px;
        color: #94a3b8;
        text-decoration: none;
    }

        .back:hover {
            color: #38bdf8;
        }
</style>

<div class="container">

    @if (TempData["errorenroll"] != null)
    {
        <div class="alert">
            ⚠ @TempData["errorenroll"]
        </div>
    }

    <!-- HERO -->
    <div class="hero-card">

        <span class="badge">Course</span>

        <h2>@Model.courseName</h2>

        <p>@Model.courseDescription</p>

        <div style="margin:10px 0;">
            <span class="badge">💰 @Model.coursePrice EGP</span>
            <span class="badge">👨‍🏫 @Model.teacherName</span>
            <span class="badge">🎓 Professional Level</span>
        </div>

        @if (User.Identity.IsAuthenticated && User.IsInRole("Student"))
        {
            <form method="post" asp-action="Enroll" asp-controller="Student">
                @Html.AntiForgeryToken()
                <input type="hidden" name="courseId" value="@Model.courseId" />

                <button class="btn-primary">
                    🚀 Enroll Now
                </button>
            </form>
        }

    </div>

    <!-- LESSONS -->
    <div class="section-title">📚 Course Lessons</div>

    @if (User.IsInRole("Admin"))
    {
        <a class="add-btn"
           asp-action="AddLesson"
           asp-controller="Lesson"
           asp-route-courseid="@Model.courseId">
            + Add Lesson
        </a>
    }

    <div class="row" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:15px;">

        @if (Model.lessons != null)
        {
            foreach (var lesson in Model.lessons)
            {
                if (!lesson.isDeleted)
                {
                    <div class="lesson-card">

                        <h4 style="color:#fbcfe8;">▶ @lesson.lessonName</h4>
                        <div style="margin-bottom:8px;color:#94a3b8;font-size:12px;">
                            Lesson Video
                        </div>
                        @{
                            var videoUrl = lesson.lessonVideoUrl;

                            if (videoUrl.Contains("watch?v="))
                            {
                                var videoId = videoUrl.Split("watch?v=")[1].Split('&')[0];
                                videoUrl = "https://www.youtube.com/embed/" + videoId;
                            }
                            else if (videoUrl.Contains("youtu.be/"))
                            {
                                var videoId = videoUrl.Split("youtu.be/")[1].Split('?')[0];
                                videoUrl = "https://www.youtube.com/embed/" + videoId;
                            }
                        }
                        <iframe width="100%" height="315"
                                src="@videoUrl"
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen>
                        </iframe>
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Student"))
                        {
                            <form asp-action="CompleteLesson"
                                  method="post"
                                  asp-controller="Student"
                                  style="margin-top:12px;">

                                <input type="hidden"
                                       name="lessonId"
                                       value="@lesson.lessonId" />

                                <button type="submit" class="complete-btn">
                                    ✅ Mark as Completed
                                </button>

                            </form>
                        }
                        <a href="@lesson.lessonVideoUrl"
                           target="_blank"
                           style="display:inline-block;margin-top:10px;
                            padding:8px 12px;border-radius:10px;
                            background:linear-gradient(135deg,#38bdf8,#f9a8d4);
                            color:white;text-decoration:none;font-weight:700;">
                            ▶ Watch on YouTube
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <div style="margin-top:10px;display:flex;gap:8px;">

                                <a class="btn-small edit"
                                   asp-action="EditLesson"
                                   asp-controller="Lesson"
                                   asp-route-lessonId="@lesson.lessonId"
                                   asp-route-courseId="@lesson.courseId">
                                    ✏ Edit
                                </a>

                                <form method="post" asp-action="DeleteLesson" asp-controller="Lesson">
                                    <input type="hidden" name="cId" value="@lesson.courseId" />
                                    <input type="hidden" name="lId" value="@lesson.lessonId" />

                                    <button class="btn-small delete">
                                        🗑 Delete
                                    </button>
                                </form>

                            </div>
                        }

                    </div>
                }
            }
        }

    </div>

    <a class="back" asp-action="Index" asp-controller="Home">
        ← Back to Home
    </a>

</div>