@model BrightPath.ViewModels.EditProfileViewModel

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma;
        background: #0b1220;
        color: #e2e8f0;
    }

    .page {
        min-height: 90vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 30px;
    }

    .card {
        width: 450px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(56,189,248,0.2);
        border-radius: 22px;
        padding: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
        transition: .3s;
    }

        .card:hover {
            transform: translateY(-6px);
        }

    h2 {
        text-align: center;
        margin-bottom: 20px;
        font-weight: 900;
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    label {
        font-size: 13px;
        color: #cbd5e1;
        margin-bottom: 6px;
        display: block;
    }

    input[type="text"],
    input[type="file"] {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid rgba(56,189,248,0.3);
        background: rgba(255,255,255,0.05);
        color: white;
        outline: none;
        margin-bottom: 15px;
        transition: .3s;
    }

    input:focus {
        border-color: #38bdf8;
        box-shadow: 0 0 12px rgba(56,189,248,0.25);
    }

    .btn {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 14px;
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        color: white;
        font-weight: 700;
        cursor: pointer;
        transition: .3s;
        margin-top: 5px;
    }

        .btn:hover {
            transform: scale(1.03);
        }

    .link {
        display: block;
        text-align: center;
        margin-top: 15px;
        color: #38bdf8;
        text-decoration: none;
        font-weight: 600;
    }

        .link:hover {
            color: #f9a8d4;
        }

    .upload-box {
        border: 2px dashed rgba(56,189,248,0.4);
        padding: 18px;
        border-radius: 14px;
        text-align: center;
        margin-bottom: 15px;
        cursor: pointer;
        transition: .3s;
    }

        .upload-box:hover {
            background: rgba(56,189,248,0.05);
        }

</style>

<div class="page">

    <div class="card">

        <h2>✏️ Edit Profile</h2>

        <form method="post" asp-action="EditProfile" asp-controller="Profile" enctype="multipart/form-data">

            <label>Name</label>
            <input asp-for="name" type="text" placeholder="Enter your name" />

            <label>Profile Image</label>
            <div class="upload-box">
                📷 Choose new profile image
                <input type="file" name="image" style="margin-top:10px;" />
            </div>

            <button type="submit" class="btn">
                Save Changes
            </button>

        </form>

        <a asp-action="ChangePassword" asp-controller="Account"
           class="link">
            🔒 Change Password
        </a>

    </div>

</div>