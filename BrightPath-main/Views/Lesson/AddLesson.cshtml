@model Lessons

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma;
        background: radial-gradient(circle at top left, #38bdf8, transparent 40%), radial-gradient(circle at bottom right, #f9a8d4, transparent 45%), linear-gradient(135deg,#0b1220,#0f172a);
        color: #e2e8f0;
    }

    .page {
        max-width: 650px;
        margin: 60px auto;
        padding: 20px;
    }

    .card {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(125,211,252,0.2);
        backdrop-filter: blur(12px);
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        transition: .3s;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .icon {
        text-align: center;
        font-size: 46px;
        margin-bottom: 10px;
    }

    .title {
        text-align: center;
        font-size: 26px;
        font-weight: 800;
        margin-bottom: 25px;
        color: #fbcfe8;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-control {
        width: 100%;
        padding: 14px;
        border-radius: 12px;
        border: 1px solid rgba(125,211,252,0.3);
        background: rgba(255,255,255,0.05);
        color: white;
        outline: none;
        font-size: 14px;
        transition: .3s;
    }

        .form-control:focus {
            border-color: #38bdf8;
            box-shadow: 0 0 10px rgba(56,189,248,0.4);
        }

        .form-control::placeholder {
            color: #94a3b8;
        }

    .error {
        color: #fca5a5;
        font-size: 12px;
        margin-top: 5px;
        display: block;
    }

    .btn {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 14px;
        font-size: 16px;
        font-weight: 700;
        color: white;
        cursor: pointer;
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        transition: .3s;
        margin-top: 10px;
    }

        .btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px rgba(249,168,212,0.25);
        }
</style>

<div class="page">

    <div class="card">

        <div class="icon">🎬</div>
        <div class="title">Add New Lesson</div>

        <form method="post">

            <input type="hidden" asp-for="courseId" />

            <div class="form-group">
                <input class="form-control"
                       type="text"
                       asp-for="lessonName"
                       placeholder="Enter lesson name" />
                <span class="error" asp-validation-for="lessonName"></span>
            </div>

            <div class="form-group">
                <input class="form-control"
                       type="text"
                       asp-for="lessonVideoUrl"
                       placeholder="Paste video URL (YouTube, etc.)" />
                <span class="error" asp-validation-for="lessonVideoUrl"></span>
            </div>

            <button class="btn" type="submit">
                ➕ Add Lesson
            </button>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}