@model Lessons

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma;
        background: #0b1220;
        color: #e2e8f0;
    }

    .page {
        min-height: 90vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 30px;
    }

    .card {
        width: 480px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(56,189,248,0.2);
        border-radius: 22px;
        padding: 30px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
        transition: .3s;
    }

        .card:hover {
            transform: translateY(-6px);
        }

    .icon {
        font-size: 42px;
        text-align: center;
        margin-bottom: 10px;
    }

    .title {
        text-align: center;
        font-size: 24px;
        font-weight: 900;
        margin-bottom: 20px;
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    label {
        font-size: 13px;
        color: #cbd5e1;
        margin-bottom: 6px;
        display: block;
    }

    input {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid rgba(56,189,248,0.3);
        background: rgba(255,255,255,0.05);
        color: white;
        outline: none;
        transition: .3s;
        margin-bottom: 12px;
    }

        input:focus {
            border-color: #38bdf8;
            box-shadow: 0 0 12px rgba(56,189,248,0.25);
        }

    .hint {
        font-size: 11px;
        color: #94a3b8;
        margin-top: -8px;
        margin-bottom: 12px;
    }

    .btn {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        cursor: pointer;
        color: white;
        background: linear-gradient(135deg,#38bdf8,#f9a8d4);
        transition: .3s;
    }

        .btn:hover {
            transform: scale(1.03);
        }

</style>

<div class="page">

    <div class="card">

        <div class="icon">✏️</div>
        <div class="title">Edit Lesson</div>

        <form method="post" asp-controller="Lesson" asp-action="EditLesson">

            <input type="hidden" asp-for="lessonId" />
            <input type="hidden" asp-for="courseId" />

            <label>Lesson Name</label>
            <input asp-for="lessonName" placeholder="Enter lesson name" />
            <div class="hint">Update your lesson title</div>

            <label>Video URL</label>
            <input asp-for="lessonVideoUrl" placeholder="YouTube or video link" />
            <div class="hint">Paste a valid video URL</div>

            <button class="btn" type="submit">
                🚀 Update Lesson
            </button>

        </form>

    </div>

</div>